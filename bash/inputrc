# ema-pe's GNU Readline configuration.
#
# Reminder: this file is automatically read by the GNU readline library. Bash
# uses this library.

# Explicitly set Emacs-style keybindings. For many years I used Vim-style
# bindings, but I've since switched back to the default. I still use Neovim as
# my default text editor :)
set editing-mode emacs
set keymap emacs

# Show colors to indicate file type for completions. By default is off.
set colored-stats on

# Ignore case on completion or during searching.
set completion-ignore-case on
